<div class="modal fade show" id="myModal" style="display:block; background-color: rgba(10,10,10,.8);" aria-modal="true" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Přejmenovat</h4>
                <button type="button" class="close"
                        @onclick="@Cancel">
                    &times;
                </button>
            </div>
            <div class="modal-body">
                <div>
                    <p style="margin-bottom:0.3rem;">Přejmenovat "@name" na:</p>
                </div>
                <div>
                    <input type="text" @bind-value="name" class="width100p"/>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary"
                        @onclick=@Ok>
                    Uložit
                </button>
                <button type="button" class="btn btn-warning"
                        @onclick="@Cancel">
                    Zrušit
                </button>
                
            </div>
        </div>
    </div>
</div>
@code {
    [Parameter] public EventCallback<string> OnClose { get; set; }
    [Parameter] public string name { get; set; }
    private Task Cancel()
    {
        return OnClose.InvokeAsync("");
    }
    private Task Ok()
    {
        return OnClose.InvokeAsync(name);
    }

}
